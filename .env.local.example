# Reference for optional manual overrides.
# Normal local installs read one raw key per file from secrets\<ENV_VAR_NAME>.
# To override those values, copy this file to backend\.env.local and fill in keys.
# backend\.env.local is gitignored; never commit real keys.

# Image generation
GOOGLE_API_KEY=your-google-ai-key-here
OPENAI_API_KEY=your-openai-key-here

# Build Sheet LLM
ANTHROPIC_API_KEY=your-anthropic-key-here

# Search Grounding
PERPLEXITY_API_KEY=your-perplexity-key-here
